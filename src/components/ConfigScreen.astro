<section class="boot-screen" data-screen="config">
  <div class="config-card">
    <span class="eyebrow">Configuration needed</span>
    <h1>Connect Supabase</h1>
    <p>
      Add <code>PUBLIC_SUPABASE_URL</code> and
      <code>PUBLIC_SUPABASE_ANON_KEY</code> to your environment. Optionally set
      <code>PUBLIC_SUPABASE_CHAT_FUNCTION</code> if your edge function is not
      named <code>chat</code>.
    </p>
  </div>
</section>
