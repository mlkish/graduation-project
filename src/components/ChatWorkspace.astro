<section class="chat-app" data-screen="chat" aria-label="Chat workspace">
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-head">
      <div class="brand-lockup">
        <span class="brand-mark">R</span>
        <span class="brand-name">RAGify AI</span>
      </div>
      <button
        class="icon-button mobile-only"
        id="close-sidebar"
        type="button"
        aria-label="Close sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
      </button>
    </div>

    <div class="sidebar-tabs" role="tablist" aria-label="Sidebar sections">
      <button
        class="sidebar-tab active"
        id="tab-chats"
        type="button"
        role="tab"
        aria-selected="true"
        aria-controls="panel-chats"
        data-tab="chats"
      >
        Chats
        <span class="tab-count" id="chat-count">0</span>
      </button>
      <button
        class="sidebar-tab"
        id="tab-files"
        type="button"
        role="tab"
        aria-selected="false"
        aria-controls="panel-files"
        data-tab="files"
      >
        Files
        <span class="tab-count" id="file-count">0</span>
      </button>
    </div>

    <div
      class="sidebar-panel active"
      id="panel-chats"
      role="tabpanel"
      aria-labelledby="tab-chats"
      data-panel="chats"
    >
      <button class="new-chat-button" id="new-chat" type="button">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5v14M5 12h14" /></svg>
        New chat
      </button>
      <div class="scroll-list chat-list" id="chat-list" role="list"></div>
    </div>

    <div
      class="sidebar-panel"
      id="panel-files"
      role="tabpanel"
      aria-labelledby="tab-files"
      data-panel="files"
    >
      <label class="upload-button" id="upload-label">
        <input
          type="file"
          id="file-input"
          accept=".txt,.md,.markdown,.text,text/plain,text/markdown"
          hidden
        />
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 16v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
          <path d="M12 3v12M8 7l4-4 4 4" />
        </svg>
        <span id="upload-label-text">Upload a file</span>
      </label>
      <p class="file-status" id="file-status" data-tone="neutral"></p>
      <div class="scroll-list file-list" id="file-list" role="list"></div>
    </div>

    <div class="account-card">
      <div class="account-info">
        <span class="account-label">Signed in</span>
        <strong id="account-email">…</strong>
      </div>
      <button class="ghost-button" id="sign-out" type="button">Sign out</button>
    </div>
  </aside>

  <div class="scrim" id="scrim" hidden></div>

  <section class="conversation">
    <header class="chat-header">
      <button
        class="icon-button mobile-only"
        id="open-sidebar"
        type="button"
        aria-label="Open sidebar"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
      </button>
      <div class="chat-header-titles">
        <span class="eyebrow">Conversation</span>
        <h1 id="active-title">New chat</h1>
      </div>
      <div class="status-chip" id="connection-status" data-tone="neutral">Ready</div>
    </header>

    <div class="messages" id="messages" aria-live="polite">
      <div class="empty-state">
        <span class="empty-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
        </span>
        <h2>Start a conversation</h2>
        <p>
          Upload documents from the Files tab and RAGify AI will answer using them
          as context. Every thread is saved automatically.
        </p>
      </div>
    </div>

    <form class="composer" id="composer">
      <label class="sr-only" for="prompt">Message RAGify AI</label>
      <textarea
        id="prompt"
        name="prompt"
        rows="1"
        placeholder="Send a message…"
        required></textarea>
      <button class="send-button" id="send-message" type="submit">Send</button>
    </form>
  </section>

  <div class="modal" id="file-viewer" hidden>
    <div class="modal-backdrop" data-close-viewer></div>
    <div
      class="modal-panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="file-viewer-title"
    >
      <header class="modal-head">
        <div class="modal-titles">
          <span class="modal-eyebrow">File</span>
          <h2 class="modal-title" id="file-viewer-title">Document</h2>
        </div>
        <button
          class="icon-button"
          id="close-file-viewer"
          type="button"
          data-close-viewer
          aria-label="Close file viewer"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12" /></svg>
        </button>
      </header>
      <div class="modal-body" id="file-viewer-body"></div>
    </div>
  </div>
</section>
